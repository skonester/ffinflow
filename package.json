{
  "name": "ffinflow",
  "version": "1.0.0",
  "description": "FFmpeg Media player",
  "author": "Skonester",
  "homepage": "https://github.com/skonester",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder -p always",
    "postinstall": "node copyFFmpeg.js"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "electron-log": "^5.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "music-metadata": "^7.14.0",
    "srt-to-vtt": "^1.1.3",
    "subtitle": "^4.2.1",
    "webvtt-parser": "^2.2.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.ffinflow.mediaplayer",
    "productName": "ffinflow",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "ffmpeg-binaries/",
        "to": "ffmpeg-binaries/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "private": false
    }
  }
}